# EditorConfig configuration file
# This file defines coding style preferences for different file types
# See https://editorconfig.org/ for more information

# Indicates that this is the root configuration file (no parent configs will be searched)
root = true

# Settings for all files (* matches any file)
[*]
# Character encoding: use UTF-8 for all files
charset = utf-8
# Line ending style: use Unix-style line feeds (LF)
end_of_line = lf
# Ensure all files end with a newline character
insert_final_newline = true
# Remove any trailing whitespace from lines
trim_trailing_whitespace = true
# Indentation style: use spaces instead of tabs
indent_style = space
# Number of spaces per indentation level
indent_size = 4

# Settings specifically for Markdown files (*.md)
[*.md]
# Don't trim trailing whitespace in Markdown (useful for line breaks)
trim_trailing_whitespace = false

# Settings for YAML files (*.yml and *.yaml)
[*.{yml,yaml}]
# Use 2 spaces for indentation in YAML files
indent_size = 2

# Settings specifically for CMakeLists.txt
[CMakeLists.txt]
# Use tabs for indentation in CMake files
indent_style = tab
# Tab width of 8 spaces (CMake convention)
indent_size = 8